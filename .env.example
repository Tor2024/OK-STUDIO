# ═══════════════════════════════════════════════════
# OK Studio — Environment Variables
# ═══════════════════════════════════════════════════

# ─── Website ───────────────────────────────────────
SITE_URL=https://webstudio-ok.de

# ─── GitHub (für Admin-Panel) ──────────────────────
# Erstelle Token: https://github.com/settings/tokens
# Scope: repo (full control of private repositories)
VITE_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_GITHUB_OWNER=Tor2024
VITE_GITHUB_REPO=OK-STUDIO
VITE_GITHUB_BRANCH=main

# Admin Panel Password (SHA-256 hash)
# Сгенерируйте хеш: npm run password:generate
# По умолчанию: "password"
VITE_ADMIN_PASSWORD_HASH=5e884898da28047151d0e56f8dc6292773603d0d6aabbdd62a11ef721d1542d8

# ─── Google Analytics ──────────────────────────────
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_PROPERTY_ID=123456789

# Google Analytics Service Account (für Reporting API)
# Erstelle Service Account in Google Cloud Console
# Lade JSON herunter und füge hier als einzeilige String ein
GOOGLE_ANALYTICS_CREDENTIALS={"type":"service_account","project_id":"..."}

# ─── Google My Business ────────────────────────────
# Erstelle Review-Link in Google My Business
# "Bewertungen erhalten" → "Link teilen"
GOOGLE_REVIEW_LINK=https://g.page/r/YOUR_PLACE_ID/review

# ─── Email Service (Resend) ────────────────────────
# Registriere auf resend.com
# API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Offizielle Kontakt-Email
OFFICIAL_CONTACT_EMAIL=info@webstudio-ok.de

# ─── Social Media APIs (Optional) ──────────────────

# LinkedIn
# https://www.linkedin.com/developers/
# Erstelle App → OAuth 2.0 → Access Token
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_ID=

# Facebook
# https://developers.facebook.com/
# Erstelle App → Access Token generieren
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# Twitter/X
# https://developer.twitter.com/
# Erstelle App → Bearer Token
TWITTER_BEARER_TOKEN=

# XING (optional, für Deutschland)
XING_API_KEY=

# ─── Telegram (für Benachrichtigungen) ─────────────
# Erstelle Bot mit @BotFather
# /newbot → Token kopieren
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ═══════════════════════════════════════════════════
# Setup-Anleitung
# ═══════════════════════════════════════════════════
#
# 1. Kopiere diese Datei zu .env
#    cp .env.example .env
#
# 2. Fülle alle Werte aus
#
# 3. Teste die Konfiguration:
#    npm run analytics:setup
#    npm run reviews:send "Test" test@example.com "Test"
#
# 4. Starte Development Server:
#    npm run dev
#
